---
import Layout from '../layouts/Layout.astro';
import { GYM_NAME } from '../lib/constants';
import CTABanner from '../components/home/CTABanner.astro';
import { Target, Heart, Users, MapPin } from 'lucide-react';

const values = [
  { icon: Target, title: 'Fokus & Hasil', desc: 'Kami mengutamakan program yang terukur dan disesuaikan dengan goals spesifik tubuh wanita.' },
  { icon: Heart, title: 'Ruang Aman', desc: 'Lingkungan bebas judgment 100% wanita untuk kebebasan berekspresi saat berolahraga.' },
  { icon: Users, title: 'Komunitas Sehat', desc: 'Saling mendukung antar member untuk konsisten dan saling menyemangati.' },
  { icon: MapPin, title: 'Pusat Kota', desc: 'Lokasi strategis di Banjarmasin yang mudah dijangkau darimana saja.' },
];
---

<Layout title={`Tentang Kami | ${GYM_NAME}`} description="Mengenal lebih dekat visi dan misi studio fitness khusus wanita pertama di Banjarmasin.">
  <div class="bg-brand-dark py-20 mt-[-80px] pt-[120px]">
    <div class="container-brand text-center text-white">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold mb-6">Tentang Kami</h1>
      <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto font-light">
        Lebih dari sekadar gym, kami adalah rumah dan komunitas pemberdayaan fisik serta mental bagi wanita Banjarmasin.
      </p>
    </div>
  </div>

  <section class="section-padding bg-white">
    <div class="container-brand">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="relative">
            <div class="absolute top-0 right-0 -translate-y-4 translate-x-4 w-24 h-24 bg-brand-primary-light/20 rounded-full blur-xl"></div>
            <img 
              src="https://images.unsplash.com/photo-1518310383802-640c2de311b2?q=80&w=800&h=1000&fit=crop" 
              alt="Gym Founder" 
              class="rounded-3xl shadow-brand-xl object-cover w-full h-[500px]"
            />
            <div class="absolute -bottom-8 -left-8 bg-brand-primary text-white p-6 rounded-2xl shadow-brand-lg">
              <div class="font-display font-bold text-4xl mb-1">2017</div>
              <div class="text-sm font-medium">Tahun Berdiri</div>
            </div>
          </div>
        </div>
        
        <div>
          <h2 class="text-sm font-bold text-brand-primary tracking-wider uppercase mb-2">Sejarah Kami</h2>
          <h3 class="text-3xl md:text-4xl font-display font-bold text-brand-dark mb-6">Mulai dari Kebutuhan Akan Ruang Aman</h3>
          <div class="space-y-4 text-brand-body leading-relaxed">
            <p>
              Berawal dari keresahan banyak wanita di Banjarmasin yang merasa kurang nyaman dan canggung saat berlatih di gym campuran komersial, <strong>{GYM_NAME}</strong> hadir sebagai solusi nyata.
            </p>
            <p>
              Kami mengerti bahwa bagi sebagian besar wanita, pergi ke gym bukan sekadar untuk membentuk otot, tapi juga ruang untuk me time, merilis stres, dan membangun kepercayaan diri. Sayangnya, banyak yang mengurungkan niat karena tidak adanya fasilitas khusus wanita yang komprehensif.
            </p>
            <p>
              Sejak 2017, kami telah membantu lebih dari 2.000+ wanita bertransformasi. Dari ibu rumah tangga, mahasiswi, hingga wanita karir. Kami menyiapkan lingkungan di mana Anda tidak perlu mengkhawatirkan pakaian apa yang Anda kenakan atau bagaimana penampilan Anda saat berkeringat.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-brand-light">
    <div class="container-brand text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-brand-dark mb-16">Nilai Utama Kami</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 mt-8 lg:grid-cols-4 gap-8">
        {values.map((v) => (
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100/50 hover:shadow-brand-md transition-shadow group">
            <div class="mx-auto w-16 h-16 bg-brand-primary/10 text-brand-primary flex items-center justify-center rounded-full mb-6 group-hover:bg-brand-primary group-hover:text-white transition-colors duration-300">
              <v.icon size={28} />
            </div>
            <h4 class="text-xl font-display font-bold text-brand-dark mb-3 justify-center">{v.title}</h4>
            <p class="text-sm text-brand-body leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner />
</Layout>
