---
import Layout from '../layouts/Layout.astro';
import { GYM_NAME, FULL_ADDRESS, WA_LINK, WA_NUMBER, GYM_EMAIL, GOOGLE_MAPS_URL, IG_HANDLE } from '../lib/constants';
import { MapPin, Phone, Mail, Clock, Instagram } from 'lucide-react';
import ContactForm from '../components/forms/ContactForm';
---

<Layout title={`Kontak & Lokasi | ${GYM_NAME}`} description="Lokasi, jam operasional, dan kontak WhatsApp resmi gym kami di Banjarmasin.">
  <div class="bg-brand-dark py-20 mt-[-80px] pt-[120px]">
    <div class="container-brand text-center text-white">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold mb-6">Hubungi Kami</h1>
      <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto font-light">
        Punya pertanyaan lebih lanjut? Jangan ragu untuk mengirim pesan kepada kami.
      </p>
    </div>
  </div>

  <section class="section-padding bg-brand-light">
    <div class="container-brand">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 mb-8">
            <h3 class="text-2xl font-display font-bold text-brand-dark mb-6">Informasi Kontak</h3>
            <ul class="space-y-6">
              <li class="flex items-start">
                <div class="w-10 h-10 rounded-full bg-brand-primary-bg flex items-center justify-center text-brand-primary mr-4 shrink-0">
                  <MapPin size={20} />
                </div>
                <div>
                  <h4 class="font-bold text-brand-dark mb-1">Alamat Studio</h4>
                  <p class="text-brand-body text-sm leading-relaxed">{FULL_ADDRESS}</p>
                </div>
              </li>
              <li class="flex items-start">
                <div class="w-10 h-10 rounded-full bg-[#25D366]/10 flex items-center justify-center text-[#25D366] mr-4 shrink-0">
                  <Phone size={20} />
                </div>
                <div>
                  <h4 class="font-bold text-brand-dark mb-1">WhatsApp Fast Response</h4>
                  <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="text-brand-body text-sm hover:text-[#25D366] transition-colors">{WA_NUMBER}</a>
                </div>
              </li>
              <li class="flex items-start">
                <div class="w-10 h-10 rounded-full bg-brand-primary-bg flex items-center justify-center text-brand-primary mr-4 shrink-0">
                  <Mail size={20} />
                </div>
                <div>
                  <h4 class="font-bold text-brand-dark mb-1">Email</h4>
                  <a href={`mailto:${GYM_EMAIL}`} class="text-brand-body text-sm hover:text-brand-primary transition-colors">{GYM_EMAIL}</a>
                </div>
              </li>
              <li class="flex items-start">
                <div class="w-10 h-10 rounded-full bg-brand-primary-bg flex items-center justify-center text-brand-primary mr-4 shrink-0">
                  <Instagram size={20} />
                </div>
                <div>
                  <h4 class="font-bold text-brand-dark mb-1">Instagram</h4>
                  <a href={`https://instagram.com/${IG_HANDLE.replace('@', '')}`} target="_blank" rel="noopener noreferrer" class="text-brand-body text-sm hover:text-brand-primary transition-colors">{IG_HANDLE}</a>
                </div>
              </li>
            </ul>
          </div>

          <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
            <h3 class="text-2xl font-display font-bold text-brand-dark mb-6 flex items-center">
              <Clock size={24} class="text-brand-primary mr-3" /> Jam Operasional
            </h3>
            <ul class="space-y-4 text-brand-body">
              <li class="flex justify-between items-center py-2 border-b border-gray-100">
                <span class="font-medium text-brand-dark">Senin - Jumat</span>
                <span>06:00 - 21:00</span>
              </li>
              <li class="flex justify-between items-center py-2 border-b border-gray-100">
                <span class="font-medium text-brand-dark">Sabtu</span>
                <span>07:00 - 20:00</span>
              </li>
              <li class="flex justify-between items-center py-2 text-brand-primary font-medium">
                <span>Minggu & Hari Libur</span>
                <span>08:00 - 17:00</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="h-full flex flex-col">
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 mb-8 flex-grow">
            <h3 class="text-2xl font-display font-bold text-brand-dark mb-6">Tinggalkan Pesan</h3>
            <ContactForm client:load />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="h-[400px] md:h-[500px] w-full bg-gray-200">
    <iframe 
      src={GOOGLE_MAPS_URL} 
      width="100%" 
      height="100%" 
      style="border:0;" 
      allowfullscreen="" 
      loading="lazy" 
      referrerpolicy="no-referrer-when-downgrade"
      title="Peta Lokasi Gym"
    ></iframe>
  </section>
</Layout>
