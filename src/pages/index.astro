---
import Layout from '../layouts/Layout.astro';
import { GYM_NAME, TAGLINE } from '../lib/constants';
import CTABanner from '../components/home/CTABanner.astro';
import WhyChooseUs from '../components/home/WhyChooseUs.astro';
import ProgramPreview from '../components/home/ProgramPreview.astro';
import FacilitiesTeaser from '../components/home/FacilitiesTeaser.astro';
import TestimonialStrip from '../components/home/TestimonialStrip';
import PricingTeaser from '../components/home/PricingTeaser.astro';
---

<Layout title={`${GYM_NAME} | Gym Khusus Wanita Banjarmasin`} description={TAGLINE}>
  <section class="relative h-[90vh] min-h-[600px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.unsplash.com/photo-1548690312-e3b507d8c110?q=80&w=1920&h=1080&fit=crop" 
        alt="Gym khusus wanita Banjarmasin" 
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-brand-dark/60 backdrop-blur-[2px]"></div>
    </div>
    
    <div class="container-brand relative z-10 text-center px-4 mt-8 md:mt-0">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold text-white mb-6 animate-in slide-in-from-bottom-8 fade-in duration-1000">
        Women's Fit Studio
      </h1>
      <p class="text-lg md:text-2xl text-white/90 mb-10 max-w-2xl mx-auto font-body font-light animate-in slide-in-from-bottom-8 fade-in duration-1000 delay-150 fill-mode-both">
        {TAGLINE}
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 animate-in slide-in-from-bottom-8 fade-in duration-1000 delay-300 fill-mode-both">
        <a href="/daftar" class="w-full sm:w-auto bg-brand-primary text-white px-8 py-4 rounded-full font-medium text-lg hover:bg-brand-primary-light transition-all shadow-brand-lg hover:shadow-brand-xl hover:-translate-y-1">
          Daftar Trial Gratis
        </a>
        <a href="/program" class="w-full sm:w-auto bg-white/10 backdrop-blur-md text-white border border-white/20 px-8 py-4 rounded-full font-medium text-lg hover:bg-white/20 transition-all">
          Lihat Program Kami
        </a>
      </div>
      
      <div class="flex flex-wrap justify-center gap-6 md:gap-12 animate-in slide-in-from-bottom-4 fade-in duration-1000 delay-500 fill-mode-both">
        <div class="text-white text-center">
          <div class="font-display font-bold text-2xl text-brand-primary-light">⭐ 4.7/5</div>
          <div class="text-sm text-white/70">dari 223 Ulasan</div>
        </div>
        <div class="text-white text-center">
          <div class="font-display font-bold text-2xl text-brand-primary-light">7+ Tahun</div>
          <div class="text-sm text-white/70">Beroperasi</div>
        </div>
        <div class="text-white text-center">
          <div class="font-display font-bold text-2xl text-brand-primary-light">100%</div>
          <div class="text-sm text-white/70">Khusus Wanita</div>
        </div>
      </div>
    </div>
  </section>

  <WhyChooseUs />
  <ProgramPreview />
  <FacilitiesTeaser />
  <TestimonialStrip client:visible />
  <PricingTeaser />
  <CTABanner />
</Layout>
